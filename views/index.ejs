<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TITAN_V9.5 | GOD_INDEX_TERMINAL</title>
    <style>
        :root { 
            --red: #ff0000; 
            --red-glow: rgba(255, 0, 0, 0.4);
            --bg: #010101; 
            --border: #1a1a1a; 
            --text: #888; 
            --font-main: 'JetBrains Mono', 'Fira Code', monospace;
            --shodan-blue: #00d9ff; 
            --shodan-glow: rgba(0, 217, 255, 0.4);
            --sidebar-glass: rgba(10, 10, 10, 0.98);
            --panel-bg: #050505;
            --active-grad: linear-gradient(90deg, rgba(255,0,0,0.15) 0%, rgba(0,0,0,0) 100%);
        }

        * { box-sizing: border-box; outline: none; margin: 0; padding: 0; }
        
        ::-webkit-scrollbar { width: 5px; height: 5px; }
        ::-webkit-scrollbar-track { background: #000; }
        ::-webkit-scrollbar-thumb { background: var(--red); border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #ff3333; }

        body { 
            background: var(--bg); 
            color: var(--text); 
            font-family: var(--font-main); 
            display: flex; 
            height: 100vh; 
            width: 100vw;
            overflow: hidden;
            -webkit-font-smoothing: antialiased;
        }

        /* --- SIDEBAR ARCHITECTURE --- */
        .sidebar { 
            width: 340px; 
            margin: 20px; 
            border-radius: 35px; 
            border: 1px solid var(--border);
            background: var(--sidebar-glass); 
            backdrop-filter: blur(40px);
            display: flex; 
            flex-direction: column; 
            flex-shrink: 0; 
            z-index: 1000;
            box-shadow: 0 40px 100px rgba(0,0,0,0.9);
            position: relative;
        }

        .sidebar-header { 
            padding: 50px 20px 30px; 
            border-bottom: 1px solid rgba(255,255,255,0.03); 
            font-weight: 900; 
            letter-spacing: 12px; 
            text-align: center; 
            color: #fff; 
            text-shadow: 0 0 20px var(--red-glow); 
            font-size: 24px;
            cursor: default;
        }

        .module-list { 
            flex-grow: 1; 
            overflow-y: auto; 
            padding: 10px 15px; 
            scrollbar-width: none; 
        }
        .module-list::-webkit-scrollbar { display: none; }

        .nav-cat { 
            font-size: 10px; 
            color: #333; 
            padding: 30px 20px 10px; 
            text-transform: uppercase; 
            font-weight: 900; 
            letter-spacing: 4px; 
            border-bottom: 1px solid #0d0d0d;
            margin-bottom: 10px;
        }
        
        .nav-item { 
            padding: 16px 20px; 
            font-size: 11px; 
            color: #555; 
            cursor: pointer; 
            margin-bottom: 5px; 
            border-radius: 18px; 
            border: 1px solid transparent;
            transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1); 
            display: flex; 
            justify-content: space-between; 
            align-items: center;
        }

        .nav-item:hover { 
            background: rgba(255,255,255,0.03); 
            color: #aaa; 
            transform: translateX(5px);
        }

        .nav-item.active { 
            background: var(--active-grad); 
            color: #fff; 
            border-color: rgba(255,0,0,0.2); 
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        .nav-item.active .code-tag {
            background: var(--red);
            color: #000;
        }

        .code-tag { 
            font-size: 8px; 
            font-weight: 900; 
            padding: 4px 10px; 
            border-radius: 6px; 
            background: #111;
            color: #444;
            transition: 0.3s;
        }
        .code-tag.blue { color: var(--shodan-blue); }

        .sidebar-footer {
            background: rgba(0,0,0,0.3); 
            border-top: 1px solid rgba(255,255,255,0.03);
            padding: 30px; 
            font-size: 10px;
        }

        .sys-line { 
            display: flex; 
            justify-content: space-between; 
            margin-bottom: 8px; 
            color: #444; 
            font-weight: 900;
            text-transform: uppercase;
        }
        .sys-line span:last-child { color: var(--red); }

        /* --- WORKSPACE ARCHITECTURE --- */
        .workspace { 
            flex-grow: 1; 
            display: flex; 
            flex-direction: column; 
            background: #000; 
            position: relative;
        }

        /* Scanline Overlay */
        .workspace::before {
            content: " ";
            position: absolute;
            top: 0; left: 0; bottom: 0; right: 0;
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), 
                        linear-gradient(90deg, rgba(255, 0, 0, 0.03), rgba(0, 255, 0, 0.01), rgba(0, 0, 255, 0.03));
            z-index: 2;
            background-size: 100% 4px, 3px 100%;
            pointer-events: none;
        }

        .top-nav { 
            height: 90px; 
            display: flex; 
            align-items: center; 
            justify-content: space-between; 
            padding: 0 60px; 
            font-size: 10px; 
            border-bottom: 1px solid #080808; 
            letter-spacing: 4px; 
            color: #444; 
            z-index: 10;
        }

        .terminal { 
            flex-grow: 1; 
            overflow-y: auto; 
            padding: 40px 60px 120px; 
            z-index: 5;
            position: relative;
        }
        
        .search-hub { 
            background: rgba(10,10,10,0.9); 
            border: 1px solid var(--border); 
            display: flex; 
            position: sticky; 
            top: 0; 
            z-index: 500; 
            margin-bottom: 60px; 
            border-radius: 25px; 
            overflow: hidden;
            box-shadow: 0 25px 50px rgba(0,0,0,0.8);
            backdrop-filter: blur(20px);
        }
        
        .mod-indicator { 
            background: #000; 
            color: var(--red); 
            padding: 0 35px; 
            display: flex; 
            align-items: center; 
            font-size: 16px; 
            font-weight: 900; 
            border-right: 1px solid var(--border); 
            min-width: 150px;
            transition: 0.5s ease;
        }

        input { 
            background: transparent; 
            border: none; 
            color: #fff; 
            padding: 30px; 
            flex-grow: 1; 
            font-size: 16px; 
            font-family: var(--font-main); 
            letter-spacing: 1px;
        }

        .btn-exec { 
            background: #1a0000; 
            color: #fff; 
            border: none; 
            padding: 0 50px; 
            font-weight: 900; 
            cursor: pointer; 
            transition: 0.3s; 
            text-transform: uppercase;
            letter-spacing: 2px;
        }
        .btn-exec:hover { 
            background: var(--red); 
            box-shadow: 0 0 40px var(--red-glow); 
        }

        /* --- INTELLIGENCE GRID --- */
        #out { 
            display: grid; 
            grid-template-columns: repeat(auto-fill, minmax(500px, 1fr)); 
            gap: 30px; 
        } 

        .intel-box { 
            background: var(--panel-bg); 
            border: 1px solid #111; 
            border-radius: 30px; 
            overflow: hidden; 
            animation: boxEnter 0.5s cubic-bezier(0.19, 1, 0.22, 1); 
            height: fit-content; 
            position: relative;
            box-shadow: 0 15px 35px rgba(0,0,0,0.5);
        }

        @keyframes boxEnter {
            from { opacity: 0; transform: translateY(30px) scale(0.98); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }
        
        .box-header { 
            padding: 18px 30px; 
            background: rgba(255,255,255,0.015); 
            border-bottom: 1px solid #111; 
            border-top: 5px solid var(--red); 
            display: flex; 
            justify-content: space-between; 
            align-items: center; 
        }

        .intel-box.shodan-hit { border-top-color: var(--shodan-blue); }
        .intel-box.shodan-hit .header-title { color: var(--shodan-blue); }

        .header-title { 
            color: #fff; 
            font-size: 11px; 
            font-weight: 900; 
            letter-spacing: 2px; 
            text-transform: uppercase;
        }

        .header-sig {
            font-size: 9px;
            color: #222;
            font-weight: 900;
        }

        .row { 
            display: flex; 
            padding: 16px 30px; 
            border-bottom: 1px solid #090909; 
            font-size: 12px; 
            cursor: pointer; 
            transition: 0.2s;
        }
        .row:hover { background: rgba(255,255,255,0.02); }
        .row:last-child { border-bottom: none; }

        .key { 
            width: 160px; 
            color: #444; 
            text-transform: uppercase; 
            font-size: 9px; 
            font-weight: 900; 
            flex-shrink: 0; 
            letter-spacing: 1px;
        }
        .val { 
            color: #ccc; 
            word-break: break-all; 
            line-height: 1.6; 
            font-weight: 400;
        }
        
        .copy-popup { 
            position: fixed; 
            bottom: 40px; 
            right: 40px; 
            background: var(--red); 
            color: #fff; 
            padding: 18px 35px; 
            font-size: 12px; 
            font-weight: 900; 
            border-radius: 20px; 
            display: none; 
            z-index: 5000; 
            box-shadow: 0 20px 50px rgba(255,0,0,0.3);
            letter-spacing: 2px;
        }

        #loader {
            grid-column: 1/-1;
            text-align: center;
            padding: 100px;
            font-weight: 900;
            text-transform: uppercase;
        }

        .blink { animation: systemBlink 1.5s infinite; }
        @keyframes systemBlink { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

        /* --- MOBILE RESPONSIVE --- */
        @media (max-width: 1000px) {
            body { flex-direction: column; overflow-y: auto; }
            .sidebar { width: auto; margin: 10px; height: 300px; }
            #out { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

    <div id="copy-note" class="copy-popup">CLIPBOARD_INJECTION_SUCCESS</div>

    <div class="sidebar">
        <div class="sidebar-header">OSINTING.INFO</div>
        <div class="module-list" id="modList">
            
            <div class="nav-cat">LOCAL_DATABASE</div>
            <div class="nav-item" data-path="LOCAL_DISCORD_BREACH" data-type="BREACH" data-code="DB-01"><span>Local Discord Search</span><span class="code-tag">LOCAL</span></div>
            <div class="nav-item" data-path="/api/ghosint" data-ghosint="true" data-code="GH-01"><span>Database</span><span class="code-tag">OSINT</span></div>

            <div class="nav-cat">Social</div>
            <div class="nav-item" data-path="/api/discord2roblox" data-param="id" data-code="DR-01"><span>Discord 2 Roblox (not ready)</span><span class="code-tag">NOT</span></div>
            <div class="nav-item" data-path="/dh_discord" data-param="id" data-code="DC-01"><span>Discord Lookup</span><span class="code-tag">OSINT</span></div>
            <div class="nav-item" data-path="/dh_roblox" data-param="username" data-code="RB-01"><span>Roblox</span><span class="code-tag">CSINT</span></div>
            <div class="nav-item" data-path="/dh_username" data-param="username" data-burst="true" data-code="US-02"><span>Username Recon</span><span class="code-tag">OSINT</span></div>

            <div class="nav-cat">Human Resource</div>
            <div class="nav-item" data-path="/swedish" data-split="true" data-burst="true" data-code="SWE-01"><span>Swedish DB</span><span class="code-tag">NEW</span></div>
            <div class="nav-item" data-path="/npd" data-npd="true" data-code="NPD-01"><span>NPD Search</span><span class="code-tag">BREACH</span></div>
            <div class="nav-item" data-path="DIRECT_PHONE" data-phone="true" data-code="PH-01"><span>Phone Lookup</span><span class="code-tag">OSINT</span></div>
            <div class="nav-item" data-path="/court" data-param="q" data-burst="true" data-code="CRT-01"><span>Court Records</span><span class="code-tag">OSINT</span></div>

            <div class="nav-cat">Archive</div>
            <div class="nav-item" data-path="/doxbin" data-param="q" data-burst="true" data-code="DX-01"><span>Doxbin</span><span class="code-tag">OSINT</span></div>
            <div class="nav-item" data-path="/stealerlogs" data-param="q" data-burst="true" data-code="SL-01"><span>Stealer Logs</span><span class="code-tag">OSINT</span></div>
            <div class="nav-item" data-path="/ip" data-param="q" data-code="IP-01"><span>IP Geolocation</span><span class="code-tag">OSINT</span></div>
            <div class="nav-item" data-path="/fivem" data-param="id" data-code="5M-01"><span>FiveM Intel</span><span class="code-tag">CSINT</span></div>

            
        </div>

        <div class="sidebar-footer">
            <div class="sys-line"><span>Server status:</span><span>StableV.1</span></div>
            <div class="sys-line"><span>LINK_NODE</span><span>104.21.72.11</span></div>
            <div class="sys-line"><span>LATENCY</span><span id="ping">24ms</span></div>
        </div>
    </div>

    <div class="workspace">
        <div class="top-nav">
            <div>Status: <span style="color:var(--red);">UP</span></div>
            <div id="clock">00:00:00</div>
            <div><span style="color:#eee">Some Results are bugged use with caution.</span></div>
        </div>

        <div class="terminal">
            <div class="search-hub">
                <div class="mod-indicator" id="modTag">INIT</div>
                <input type="text" id="target" placeholder="PLEASE SELECT A MODULE FROM THE LEFT..." autocomplete="off">
                <button class="btn-exec" id="executeBtn">Search</button>
            </div>
            <div id="out"></div>
        </div>
    </div>

<script>
    /**
     * TITAN_CORE_V9.5 ENGINE
     * RECURSIVE OMNI-BURST LOGIC INTEGRATED
     */
    
    // --- STATE MANAGEMENT ---
    let runtime = { 
        path: "", 
        param: "q", 
        burst: false, 
        isGhosint: false, 
        activeCode: "VOID",
        isLocked: false 
    };

    const outDisplay = document.getElementById('out');
    const inputField = document.getElementById('target');
    const modTag = document.getElementById('modTag');

    // --- INITIALIZATION ---
    function init() {
        // Register Module Click Listeners
        document.querySelectorAll('.nav-item').forEach(el => {
            el.addEventListener('click', function() {
                if (runtime.isLocked) return;

                document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
                this.classList.add('active');
                
                runtime = { 
                    path: this.dataset.path, 
                    param: this.dataset.param || "q",
                    type: this.dataset.type || "",
                    isPhone: this.dataset.phone === "true",
                    isGhosint: this.dataset.ghosint === "true",
                    burst: this.dataset.burst === "true",
                    split: this.dataset.split === "true",
                    npd: this.dataset.npd === "true",
                    activeCode: this.dataset.code
                };

                modTag.innerText = runtime.activeCode;
                
                // Theme Adaptation
                if (runtime.activeCode.includes('SH')) {
                    modTag.style.color = 'var(--shodan-blue)';
                    modTag.style.textShadow = '0 0 15px var(--shodan-glow)';
                } else {
                    modTag.style.color = 'var(--red)';
                    modTag.style.textShadow = 'none';
                }
                
                // Adaptive Placeholder
                if (runtime.npd) inputField.placeholder = "SEARCH: [FIRST] | [LAST] | [EMAIL]";
                else if (runtime.split) inputField.placeholder = "SEARCH: [FIRST NAME] [LAST NAME]";
                else inputField.placeholder = `INTERROGATE [${runtime.activeCode}] WITH TARGET DATA...`;
                
                inputField.focus();
            });
        });

        // Global Event Listeners
        document.getElementById('executeBtn').onclick = execute;
        inputField.onkeypress = (e) => { if (e.key === 'Enter') execute(); };
        
        // System Clock & Ping Simulation
        setInterval(updateClock, 1000);
        setInterval(simulatePing, 5000);

        console.log("TITAN_SYSTEM_READY: Kernel v9.5 Loaded.");
    }

    // --- CORE EXECUTION LOGIC ---
    async function execute() {
        const query = inputField.value.trim();
        if (!runtime.path || !query || runtime.isLocked) return;

        // UI Lockdown
        runtime.isLocked = true;
        const themeColor = runtime.activeCode.includes('SH') ? 'var(--shodan-blue)' : 'var(--red)';
        
        outDisplay.innerHTML = `
            <div id="loader" style="color:${themeColor}" class="blink">
                >>> INITIATING ENCRYPTED RELAY [${runtime.activeCode}]...<br>
                >>> PACKET_SIZE: ${Math.floor(Math.random()*500)}kb<br>
                >>> BYPASSING_NODE_SECURITY...
            </div>`;

        // Timeout Controller (15s for Username Recon/OSINT)
        const controller = new AbortController();
        const timeoutId = setTimeout(() => controller.abort(), 15000);

        try {
            const response = await fetch('/api/relay', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                signal: controller.signal,
                body: JSON.stringify({ 
                    endpoint: runtime.path, 
                    query: query, 
                    type: runtime.type, 
                    isPhone: runtime.isPhone, 
                    isGhosint: runtime.isGhosint, 
                    split: runtime.split, 
                    param: runtime.param 
                })
            });

            clearTimeout(timeoutId);
            const data = await response.json();
            
            if(document.getElementById('loader')) document.getElementById('loader').remove();

            if (!data.success || !data.payload) {
                renderError(data.error || 'ZERO_RESULTS_RETURNED_FROM_NODE');
                unlockUI();
                return;
            }

            // --- OMNI-BURST RECURSIVE ENGINE ---
            // Handles: Ghosint, Stealer Logs, Doxbin, Username Recon, Swedish DB, Court Records
            if (runtime.isGhosint || runtime.burst) {
                let itemsFound = 0;
                
                const processObject = (obj, sourceName = runtime.activeCode) => {
                    for (let key in obj) {
                        const val = obj[key];
                        if (Array.isArray(val)) {
                            val.forEach((item, index) => {
                                itemsFound++;
                                renderBox(flatten(item), `${sourceName}_${key.toUpperCase()}_${index+1}`);
                            });
                        } else if (typeof val === 'object' && val !== null) {
                            processObject(val, key.toUpperCase());
                        }
                    }
                };

                processObject(data.payload);
                
                // Fallback for non-nested objects
                if(itemsFound === 0) renderBox(flatten(data.payload), `${runtime.activeCode}_RESULT_01`);
            } 
            // --- SHODAN SPECIAL PARSER ---
            else if (runtime.activeCode.includes("SH")) {
                let matches = data.payload.matches || (Array.isArray(data.payload) ? data.payload : [data.payload]);
                matches.forEach((item, i) => {
                    renderBox(flatten(item), `SHODAN_ENTRY_${i+1}`, true);
                });
            } 
            // --- DEFAULT RENDERER ---
            else {
                let results = Array.isArray(data.payload) ? data.payload : [data.payload];
                results.forEach((item, i) => {
                    renderBox(flatten(item), `${runtime.activeCode}_HIT_${i+1}`);
                });
            }

        } catch (err) { 
            if (err.name === 'AbortError') renderError('NODE_TIMEOUT: TARGET_API_EXCEEDED_15S_LIMIT');
            else renderError(`CRITICAL_SYSTEM_FAULT: ${err.message}`); 
        } finally {
            unlockUI();
        }
    }

    // --- UTILITIES ---

    /**
     * FLATTEN: Recursively flattens nested objects into a single-level dictionary
     */
    function flatten(obj, prefix = '') {
        let result = {};
        for (let key in obj) {
            let propName = prefix ? `${prefix}_${key.toUpperCase()}` : key.toUpperCase();
            if (obj[key] !== null && typeof obj[key] === 'object' && !Array.isArray(obj[key])) {
                Object.assign(result, flatten(obj[key], propName));
            } else {
                result[propName] = Array.isArray(obj[key]) ? obj[key].join(' | ') : obj[key];
            }
        }
        return result;
    }

    /**
     * RENDER_BOX: Constructs the Intel Box UI element
     */
    function renderBox(data, title, isShodan = false) {
        const box = document.createElement('div');
        box.className = 'intel-box' + (isShodan ? ' shodan-hit' : '');
        
        let rows = '';
        for (let [k, v] of Object.entries(data)) {
            // Filter junk data
            if (v === null || v === "" || k === "RAW" || k.includes('ID')) continue;
            
            rows += `
                <div class="row" onclick="copyToClipboard('${v}')">
                    <div class="key">${k}</div>
                    <div class="val">${v}</div>
                </div>`;
        }
        
        const sig = `0x${Math.random().toString(16).substring(2, 6).toUpperCase()}`;
        
        box.innerHTML = `
            <div class="box-header">
                <div class="header-title">${title}</div>
                <div class="header-sig">${sig}</div>
            </div>
            <div class="box-body">${rows}</div>`;
            
        outDisplay.prepend(box);
    }

    function renderError(msg) {
        if(document.getElementById('loader')) document.getElementById('loader').remove();
        outDisplay.insertAdjacentHTML('afterbegin', `
            <div style="grid-column:1/-1; text-align:center; padding:40px; border:1px solid #200000; border-radius:20px; background:rgba(20,0,0,0.5); color:#666; font-size:11px;">
                [!] SYSTEM_ALERT: ${msg}
            </div>`);
    }

    function unlockUI() {
        runtime.isLocked = false;
        if(document.getElementById('loader')) document.getElementById('loader').remove();
    }

    function copyToClipboard(text) { 
        navigator.clipboard.writeText(text); 
        const note = document.getElementById('copy-note');
        note.style.display = 'block'; 
        setTimeout(() => note.style.display = 'none', 1200); 
    }

    function updateClock() {
        const now = new Date();
        document.getElementById('clock').innerText = now.toLocaleTimeString('en-GB', { hour12: false });
    }

    function simulatePing() {
        const ping = Math.floor(Math.random() * 40) + 10;
        document.getElementById('ping').innerText = `${ping}ms`;
    }

    // Start System
    window.onload = init;

    // Memory Guard (Prevents DOM overflow)
    setInterval(() => {
        if (outDisplay.children.length > 100) {
            for(let i=0; i<10; i++) outDisplay.removeChild(outDisplay.lastChild);
        }
    }, 60000);

</script>
</body>
</html>
